---
// HeroClip.astro (PRD §11)
// Autoplay/loop/muted silent <video> that reads like a GIF, with a poster
// fallback when a browser blocks autoplay. WebM is preferred, MP4 is fallback.
interface Props {
  mp4: string;
  webm: string;
  poster: string;
  alt: string;
}
const { mp4, webm, poster, alt } = Astro.props;
---

<figure class="hero-clip">
  <video
    autoplay
    loop
    muted
    playsinline
    preload="metadata"
    poster={poster}
    aria-label={alt}
  >
    <source src={webm} type="video/webm" />
    <source src={mp4} type="video/mp4" />
    <!-- Poster shows if <video> or autoplay is unsupported. -->
    <img src={poster} alt={alt} />
  </video>
</figure>

<style>
  .hero-clip {
    position: relative;
    margin: 0;
    border-radius: var(--radius, 12px);
    overflow: hidden;
    background: var(--clip-bg, #e9e3d5);
    border: 1px solid var(--rule, #e3ddce);
    aspect-ratio: 16 / 9;
    box-shadow: var(--shadow, 0 12px 32px rgba(40, 33, 22, 0.1));
  }
  .hero-clip video,
  .hero-clip img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Soft scrim so the looping clip recedes and the reader's eye goes to the
     headline first. Fades on hover for when they're ready to engage. */
  .hero-clip::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--clip-scrim, rgba(20, 16, 10, 0.22));
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .hero-clip:hover::after {
    opacity: 0.45;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-clip::after {
      transition: none;
    }
  }
</style>
