---
// PostLayout.astro (PRD §11)
// Hero clip at top, then title, guest line + video link, then article body.
// Includes meta description + Open Graph tags (poster as og:image).
import HeroClip from "../components/HeroClip.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { isPreviewBuild } from "../lib/site";
import "../styles/global.css"; // bundled + fingerprinted by Astro (cache-busts)
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
// Preview deployments (PR branches) are kept out of search and get a banner.
// Posts on main are published: indexable, no banner — regardless of the
// (now-cosmetic) draft frontmatter flag.
const preview = isPreviewBuild();
const noindex = preview;
const {
  title,
  description,
  pubDate,
  interviewDate,
  guest,
  guestBio,
  videoId,
  videoUrl,
  heroClip,
  tags,
} = post.data;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(heroClip.poster, Astro.site).toString();
const isoDate = pubDate.toISOString();
const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const dateStr = fmtDate(pubDate);
// The interview's YouTube publish date — the "when the conversation happened"
// date. ISO form feeds VideoObject.uploadDate; the display form goes in the meta.
const interviewIso = interviewDate ? interviewDate.toISOString() : undefined;
const interviewStr = interviewDate ? fmtDate(interviewDate) : undefined;

// JSON-LD: Article describing a profile of the guest (Person), based on the
// source interview (VideoObject). Drives SEO rich results and gives AI/answer
// engines clean entities, dates, and attribution to cite.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  image: [ogImage],
  datePublished: isoDate,
  dateModified: isoDate,
  inLanguage: "en",
  keywords: tags.join(", "),
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  author: { "@type": "Organization", name: "Tech Peeps Diaspora" },
  publisher: { "@type": "Organization", name: "Tech Peeps Diaspora" },
  about: { "@type": "Person", name: guest, description: guestBio },
  isBasedOn: videoUrl,
  video: {
    "@type": "VideoObject",
    name: title,
    description,
    thumbnailUrl: [ogImage],
    uploadDate: interviewIso ?? isoDate,
    contentUrl: videoUrl,
    embedUrl: `https://www.youtube.com/embed/${videoId}`,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Tech Peeps Diaspora</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5f1e8" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#15130e" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Tech Peeps Diaspora — Profiles"
      href="/rss.xml"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={heroClip.alt} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Tech Peeps Diaspora" />
    <meta property="article:published_time" content={isoDate} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script is:inline src="/scripts/theme.js"></script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <ThemeToggle />
    {preview && (
      <div class="draft-banner" role="status">
        <strong>Draft preview</strong> — this profile is not yet published. Shared
        for review on the pull request; please suggest any edits there.
      </div>
    )}
    <main class="post">
      <HeroClip
        mp4={heroClip.mp4}
        webm={heroClip.webm}
        poster={heroClip.poster}
        alt={heroClip.alt}
      />

      <header class="post-header">
        <p class="kicker"><a href="/">Tech Peeps Diaspora</a></p>
        <h1>{title}</h1>
        <p class="byline">
          A profile of <strong>{guest}</strong> · {guestBio}
        </p>
        <p class="meta">
          Published <time datetime={isoDate}>{dateStr}</time>
          {interviewStr && (
            <>
              {" · "}Conversation from
              <time datetime={interviewIso}>{interviewStr}</time>
            </>
          )}
          {" · "}
          <a href={videoUrl} rel="noopener" target="_blank">Watch the interview ↗</a>
        </p>
      </header>

      <article class="prose">
        <slot />
      </article>

      <footer class="post-footer">
        <ul class="tags">
          {tags.map((t) => <li>#{t}</li>)}
        </ul>
        <p class="back-to-video">
          This profile is drawn from a conversation with {guest} on Tech Peeps
          Diaspora. <a href={videoUrl} rel="noopener" target="_blank">Watch the full
          interview ↗</a>
        </p>
        <p><a href="/">← All profiles</a></p>
      </footer>
    </main>
  </body>
</html>
