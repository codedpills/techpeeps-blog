---
// index.astro (PRD §11) — reverse-chronological list of published posts.
import { getCollection } from "astro:content";
import { postFilter, isPreviewBuild } from "../lib/site";
import ThemeToggle from "../components/ThemeToggle.astro";
import Newsletter from "../components/Newsletter.astro";

const preview = isPreviewBuild();
const posts = (await getCollection("blog", postFilter)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const description =
  "Feature profiles of tech professionals across the diaspora, drawn from the Tech Peeps Diaspora interview series.";
const canonical = Astro.site ? new URL("/", Astro.site).toString() : "/";
// Default OG image = newest post's poster, if any (no broken placeholder file).
const ogImage =
  posts.length && Astro.site
    ? new URL(posts[0].data.heroClip.poster, Astro.site).toString()
    : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Tech Peeps Diaspora",
  description,
  url: canonical,
  inLanguage: "en",
  blogPost: posts.map((p) => ({
    "@type": "BlogPosting",
    headline: p.data.title,
    datePublished: p.data.pubDate.toISOString(),
    url: Astro.site
      ? new URL(`/blog/${p.slug}/`, Astro.site).toString()
      : `/blog/${p.slug}/`,
    about: { "@type": "Person", name: p.data.guest },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Tech Peeps Diaspora — Profiles</title>
    <meta name="description" content={description} />
    {preview && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5f1e8" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#15130e" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Tech Peeps Diaspora — Profiles"
      href="/rss.xml"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Tech Peeps Diaspora — Profiles" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Tech Peeps Diaspora" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="/styles/global.css" />
    <script is:inline src="/scripts/theme.js"></script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <ThemeToggle />
    <main class="home">
      <header class="home-header">
        <h1>Tech Peeps Diaspora</h1>
        <p>Profiles of tech professionals across the diaspora.</p>
      </header>

      {
        posts.length === 0 ? (
          <p style="text-align:center;color:var(--muted)">
            No published profiles yet. Merge a draft PR to publish one.
          </p>
        ) : (
          <ul class="post-grid">
            {posts.map((post) => (
              <li class="card">
                <a href={`/blog/${post.slug}/`}>
                  <img
                    class="thumb"
                    src={post.data.heroClip.poster}
                    alt={post.data.heroClip.alt}
                    loading="lazy"
                  />
                  <div class="card-body">
                    <p class="card-guest">{post.data.guest}</p>
                    <h2>{post.data.title}</h2>
                    <p class="card-desc">{post.data.description}</p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )
      }

      <Newsletter />
    </main>
    <script is:inline src="/scripts/subscribe.js"></script>
  </body>
</html>
