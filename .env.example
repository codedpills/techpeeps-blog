# Tech Peeps Diaspora — Video-to-Blog pipeline configuration.
# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Transcription (AssemblyAI) ---
ASSEMBLYAI_API_KEY=

# --- LLM rewriting (Anthropic) ---
ANTHROPIC_API_KEY=
# Configurable; override if a newer model is preferred.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- GitHub PR creation ---
# Either set GITHUB_TOKEN (a fine-grained PAT with "Contents" + "Pull requests" write)
# OR leave it blank and rely on an authenticated `gh` CLI (`gh auth login`).
GITHUB_TOKEN=
GITHUB_REPO=owner/techpeeps-blog
# Branch PRs are opened against (drafts fork from here). Defaults to "main".
BASE_BRANCH=main

# --- Editorial / source ---
HOST_NAME=
YT_PLAYLIST_URL=https://www.youtube.com/playlist?list=

# --- Newsletter (MailerLite) ---
# These are NOT used by the local pipeline. Configure them in the host, not here.
#
# Cloudflare Pages (Settings -> Environment variables) for the signup function:
#   MAILERLITE_API_KEY   token from MailerLite -> Integrations -> API  (secret)
#   MAILERLITE_GROUP_ID  group id to add new subscribers to
#
# GitHub Actions (Settings -> Secrets and variables -> Actions) for the
# auto-send-on-publish workflow (.github/workflows/newsletter.yml):
#   secret   MAILERLITE_API_KEY
#   variable MAILERLITE_GROUP_ID, NEWSLETTER_FROM, NEWSLETTER_FROM_NAME, SITE_URL
#
# For a local `make newsletter` run you can export these in your shell instead.
