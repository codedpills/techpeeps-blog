# Cloudflare Pages security headers (also valid on Netlify).
# Applied to every route. CSP is strict because the site is fully static and
# self-hosts its media (clips) — the only external reference is an <a> link to
# YouTube, which needs no CSP allowance.
#
# NOTE: if you later EMBED a YouTube <iframe>, add:
#   frame-src https://www.youtube.com https://www.youtube-nocookie.com
/*
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; media-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

# Long-cache immutable, content-hashed build assets (CSS/JS under /_astro/).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache the committed clips.
/clips/*
  Cache-Control: public, max-age=31536000, immutable

# Scripts keep a stable filename (theme.js must load render-blocking, so it is
# not hashed). Revalidate so a redeploy is picked up instead of served stale.
/scripts/*
  Cache-Control: no-cache
